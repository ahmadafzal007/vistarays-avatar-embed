# Required — LiveAvatar API key (https://app.liveavatar.com/developers)
LIVEAVATAR_API_KEY=

# Required — the LiveAvatar avatar to call
AVATAR_ID=

# Optional — voice override
VOICE_ID=

# Optional — LiveAvatar context (persona/knowledge) id
CONTEXT_ID=

# Optional — MongoDB connection string. When set, conversation transcripts are
# saved (same collection the main vistarays.de-avatars site reads) and the
# admin-panel context override stored in MongoDB is honored. When unset, the
# card still works; transcript saving is simply skipped.
MONGODB_URL=

# Optional — name/role shown on the card (defaults shown below)
NEXT_PUBLIC_MEMBER_NAME=Michael Shlomo Hamelleh
NEXT_PUBLIC_MEMBER_ROLE=Founder — CEO & Inventor
